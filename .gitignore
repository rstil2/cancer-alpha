validation_results.json
requirements_installed.flag
*.log

# === BINARY AND LARGE FILES ===
# Zip archives (reproducibility packages, submissions, etc.)
*.zip

# Word documents (binary, use .md for version control)
*.docx

# PDF files
*.pdf

# Pickle model files (keep only demo models)
*.pkl
!cancer_genomics_ai_demo_minimal/models/*.pkl

# Joblib model files
*.joblib

# PNG figures (generated output)
*.png
!manuscripts/figures/*.png

# SVG files
*.svg

# TIFF figures
*.tiff
*.tif

# Temporary Office lock files
~$*

# LaTeX auxiliary files
*.aux
*.bcf
*.bbl
*.blg
*.out
*.run.xml
*.cut

# R history
.Rhistory

