# === CORE IP PROTECTION ===
# Training scripts contain proprietary algorithms
**/train*.py
**/update*.py
**/optimize*.py
models/lightgbm_smote_production.py
models/multimodal_transformer.py

# Development and testing scripts
test_*.py
process_*.py
enhanced_data_generator.py
master_tcga_pipeline.py
multimodal_tcga_processor.py
scalable_tcga_downloader.py

# Large model files (keep only minimal demo models)
models_large_scale/
*.pth
!cancer_genomics_ai_demo_minimal/models/*.pkl
!cancer_genomics_ai_demo_minimal/models/*.json

# Data processing pipelines
data/
src/
scripts/

# Development directories with IP
api/
clinical_partnerships/
data_integration/
interpretability/
